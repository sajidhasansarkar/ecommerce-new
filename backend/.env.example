# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/labonno

# JWT
JWT_SECRET=your_super_secret_jwt_key_here

# Frontend URL (for CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# Firebase Admin — Service Account JSON (single line, stringified)
# Get this from: Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Then run: cat serviceAccountKey.json | jq -c . | pbcopy
# Paste the result below (keep it on ONE line)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"ecommerce-project-331c7","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@ecommerce-project-331c7.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# imgbb — ছবি হোস্টিংয়ের জন্য
# এখান থেকে ফ্রি API key নিন: https://api.imgbb.com/
IMGBB_API_KEY=your_imgbb_api_key_here
